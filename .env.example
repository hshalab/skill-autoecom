STORE_URL=https://www.your-shop.com
GEMINI_API_KEY=your_gemini_api_key
UPLOAD_POST_API_KEY=your_upload_post_api_key
UPLOAD_POST_PROFILE=your_upload_post_profile_name
TIMEZONE=Europe/Madrid

# Optional: override the nano-banana model (e.g. for a stable GA tag).
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Optional: absolute path to a .ttf you want to use for slide text.
# Leave blank to fall back to a system bold font (Impact / Helvetica Bold).
# BRAND_FONT_PATH=/Library/Fonts/Inter-Bold.ttf
